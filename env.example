# ============================================================
#  Mercia Chapter Payment Backend — Environment Variables
#  Rename this file to .env and fill in your real values
# ============================================================

# Your Stripe SECRET key (from stripe.com → Developers → API Keys)
# Test key starts with: sk_test_
# Live key starts with: sk_live_
STRIPE_SECRET_KEY=sk_test_YOUR_SECRET_KEY_HERE

# Your Stripe Webhook signing secret (from stripe.com → Webhooks)
# Starts with: whsec_
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# The URL of your frontend (used for CORS — prevents other sites using your server)
# Example: https://mercia-payments.netlify.app
FRONTEND_URL=https://your-frontend-url-here.netlify.app

# Port (Render/Railway set this automatically, leave as 3000 for local)
PORT=3000
